# Convex backups (generated by npm run backup)
backups/

# Seed media files are committed for auto-deployment.
# New uploads added via admin panel are stored on the persistent disk.

# Convex generated files are committed as stubs for build compatibility.
# Running `npx convex dev` will overwrite them with properly typed versions.
