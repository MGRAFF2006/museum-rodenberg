# ── Museum Rodenberg Environment Variables ──────────────────────
# Copy this file to .env (server-side) and .env.local (Vite/Convex CLI)

# ── Admin password (server-side only; NOT exposed to the browser) ──
# In production, use a strong, unique password
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── Server port ──
# Sevalla injects PORT automatically; Docker Compose uses 3000
PORT=3000

# ── Convex self-hosted backend ──
# Browser-side: Vite bakes this into the JS bundle at build time (VITE_ prefix)
# For local dev, convex dev auto-adds this to .env.local
# For Sevalla, set as a build-time env var pointing to the public Convex URL
VITE_CONVEX_URL=http://127.0.0.1:3210

# CLI-side: used by `npx convex dev` and migration scripts
# Generate the admin key: docker compose exec convex-backend ./generate_admin_key.sh
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=

# ── Convex reverse proxy (server-side only) ──
# When the museum app is served over HTTPS but the Convex backend only
# supports plain HTTP (e.g. Sevalla TCP proxy), browsers block ws://
# connections from https:// pages. The Express server proxies /convex
# to this URL, so the browser connects via same-origin wss://.
# Leave empty for local dev (direct connection via VITE_CONVEX_URL).
# On Sevalla, set this to the internal connection URL to convex-backend.
CONVEX_BACKEND_URL=

# ── LibreTranslate ──
# Self-hosted via Docker (see docker-compose.yml), or use libretranslate.com
LIBRETRANSLATE_API_URL=http://localhost:5000/translate
LIBRETRANSLATE_API_KEY=
