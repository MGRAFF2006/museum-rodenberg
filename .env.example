# ── Museum Rodenberg Environment Variables ──────────────────────
# Copy to .env (server-side) and .env.local (Vite/Convex CLI)
#
# Quick start:
#   1. cp .env.example .env
#   2. docker compose up -d convex-backend
#   3. docker compose exec convex-backend ./generate_admin_key.sh
#   4. Create .env.local with the admin key (see below)
#   5. npm run dev:full

# ── Admin password (server-side only; NOT exposed to the browser) ──
ADMIN_PASSWORD=museum2025

# ── Server port ──
PORT=3000

# ── Convex (browser-side) ──
# Vite bakes VITE_* vars into the JS bundle at build time.
# Local dev: points to Docker Convex backend directly
# Sevalla:   points to /convex reverse proxy (same-origin wss://)
VITE_CONVEX_URL=http://127.0.0.1:3210

# ── Convex (CLI-side, goes in .env.local) ──
# Used by `npx convex dev`, push-convex.sh, backup-convex.mjs
# Generate the admin key:
#   docker compose exec convex-backend ./generate_admin_key.sh
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=

# ── Convex reverse proxy (server-side, production only) ──
# When the app is served over HTTPS but Convex only supports HTTP,
# Express proxies /convex to this URL for same-origin wss://.
# Leave empty for local dev. Set in Sevalla dashboard for production.
CONVEX_BACKEND_URL=

# ── Sevalla production credentials (for CI / push-convex.sh --prod) ──
# Set these as GitHub Actions secrets: CONVEX_PROD_URL, CONVEX_PROD_ADMIN_KEY
# Or uncomment in .env.local (commented out by default):
# CONVEX_PROD_URL=http://europe-west3-002.proxy.sevalla.app:30853
# CONVEX_PROD_ADMIN_KEY=

# ── LibreTranslate ──
# Self-hosted via Docker (see docker-compose.yml), or use libretranslate.com
# In Docker Compose: http://libretranslate:5000/translate (service name)
# On host: http://localhost:5000/translate
LIBRETRANSLATE_API_URL=http://localhost:5000/translate
LIBRETRANSLATE_API_KEY=
