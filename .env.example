# LibreTranslate API credentials
# Get an API key from https://libretranslate.com, or run LibreTranslate locally (see docker-compose.yml)
LIBRETRANSLATE_API_KEY=your-api-key-here
LIBRETRANSLATE_API_URL=http://localhost:5000/translate

# Admin password for CMS login (server-side only; NOT exposed to the browser)
# In production, use a strong, unique password
ADMIN_PASSWORD=change-me-to-a-strong-password

# Server port (used by the production Express server)
PORT=3000

# Convex self-hosted backend
# Generate the admin key with: docker compose exec convex-backend ./generate_admin_key.sh
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=
